{{> header}}

<div id="background">
  <div id="page">
    <div id="contents">
      <div class="box">
        <div class="body">
          <h1>{{title}}</h1>

          <ul id="sites">
            {{#each trips}}
              <li>
                {{#if image}}
                  <a href="/travel">
                    <img src="/images/{{image}}" alt="{{name}}">
                  </a>
                {{/if}}

                <h2><a href="/travel">{{name}}</a></h2>

                {{#if description}}  <p>{{description}}</p>  {{/if}}
                {{#if description2}} <p>{{description2}}</p> {{/if}}

                {{#if length}} <p><strong>{{length}}</strong></p> {{/if}}
                {{#if start}}  <p>Starts {{start}}</p>           {{/if}}
                {{#if price}}  <p>${{price}}</p>                 {{/if}}
              </li>
            {{/each}}
          </ul>

        </div>
      </div>
    </div>
  </div>
</div>

{{> footer}}
